# Postgres connection. Use Supabase pooler URL (port 6543) in production.
DATABASE_URL=postgresql://father_jose:father_jose@localhost:5432/father-database

# Cloudflare R2 (image storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Admin Basic Auth credentials in the form "user:password"
ADMIN_BASIC_AUTH_TOKEN=admin:changeme
