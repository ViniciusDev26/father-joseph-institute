{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun build --compile src/server.ts --outfile dist/server",
    "start": "./dist/server",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/database/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@fastify/cors": "^11",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.52.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6"
  }
}
